{
  "manifest_version": 2,
  "name": "Item Price History - LeBonCoin",
  "version": "2.3.2.66",
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true,
    "type": "module"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "*://*.leboncoin.fr/*"
  ],
  "description": "Afficher de l'ancien prix de vente ainsi que la date de mise en ligne d'un article sur le site LeBonCoin",
  "homepage_url": "https://github.com/OptiPanda/lbc_old_price",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.leboncoin.fr/*"
      ],
      "js": [
        "common.js",
        "ads.js",
        "article.js",
        "main.js"
      ]
    }
  ],
  "web_accessible_resources": ["page_context.js"]
}